      { "name": "米酒", "amount": "2大勺", "note": "" },
      { "name": "生抽", "amount": "3大勺", "note": "" },
      { "name": "老抽", "amount": "1大勺", "note": "上色用" },
      { "name": "冰糖", "amount": "15g", "note": "" },
      { "name": "白胡椒粉", "amount": "少许", "note": "" },
      { "name": "食用油", "amount": "适量", "note": "炸红葱用" }
